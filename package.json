{
  "name": "cbta-financieros",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "electron",
      "esbuild",
      "prisma"
    ]
  },
  "description": "Sistema base para Control Escolar e Ingresos Propios con ROC oficial.",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"tsc -p tsconfig.node.json --watch\" \"wait-on tcp:5173 dist-electron/electron/main.js dist-electron/electron/preload.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "dev:sync-server": "tsx watch backend/sync-server.ts",
    "start:sync-server": "tsx backend/sync-server.ts",
    "dev:renderer": "vite",
    "dev:electron:tsc": "tsc -p tsconfig.node.json --watch",
    "dev:electron": "wait-on tcp:5173 dist-electron/electron/main.js dist-electron/electron/preload.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json",
    "typecheck:app": "tsc --noEmit",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "electron:compile": "tsc -p tsconfig.node.json",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:validate": "prisma validate"
  },
  "dependencies": {
    "@prisma/client": "^5.19.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "prisma": "^5.19.1",
    "tsx": "^4.22.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  }
}
