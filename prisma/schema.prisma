generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Department {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
}

model User {
  id          String      @id @default(cuid())
  username    String      @unique
  passwordHash String     @default("")
  displayName String
  role        String
  departmentId String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  department  Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  auditLogs   AuditLog[]
  receipts    RocReceipt[] @relation("ReceiptCreatedBy")
  groupAssignmentsCreated StudentGroupAssignment[] @relation("GroupAssignedBy")
  groupAssignmentsUpdated StudentGroupAssignment[] @relation("GroupUpdatedBy")
  groupAssignmentAudits GroupAssignmentAudit[] @relation("GroupAuditActor")
  academicMovements StudentAcademicMovement[] @relation("AcademicMovementActor")
  cashPayments CashPayment[] @relation("CashPaymentCreatedBy")
  grantedPermissions StudentPermission[] @relation("PermissionGrantedBy")
  closedPermissions StudentPermission[] @relation("PermissionClosedBy")
  recordedDailyStatuses StudentDailyStatus[] @relation("DailyStatusRecordedBy")
}

model Student {
  id                String         @id @default(cuid())
  enrollmentNumber  String         @unique
  officialEnrollmentNumber String? @unique
  curp              String         @unique
  rfc               String?
  firstName         String
  paternalLastName  String
  maternalLastName  String
  birthDate         DateTime?
  age               Int?
  sex               String?
  phone             String?
  studentPhoneSecondary String?
  email             String?
  motherTongue      String?
  addressLine       String
  neighborhood      String?
  locality          String?
  municipality      String?
  state             String?
  postalCode        String?
  previousSchool    String?
  secondaryAverage  Decimal?
  examRoom          String?
  schoolCycle       String
  schoolPeriod      Int            @default(1)
  semesterLevel     Int            @default(1)
  academicStatus    String?
  conductStatus     String         @default("REGULAR")
  addressConfirmedAt DateTime?
  addressConfirmedBy String?
  enrollmentStatus  String         @default("PENDIENTE_ASIGNACION")
  documentationStatus String       @default("PENDIENTE")
  status            String         @default("CAPTURADO")
  validatedAt       DateTime?
  validatedBy       String?
  preRegistrationId String?        @unique
  admissionPaymentId String?       @unique
  guardian          Guardian?
  preRegistration   PreRegistration? @relation(fields: [preRegistrationId], references: [id], onDelete: SetNull)
  admissionPayment  AdmissionPayment? @relation(fields: [admissionPaymentId], references: [id], onDelete: SetNull)
  receipts          RocReceipt[]
  cashPayments      CashPayment[]
  groupAssignment   StudentGroupAssignment?
  groupAuditLogs    GroupAssignmentAudit[]
  academicMovements StudentAcademicMovement[]
  requirementStatuses StudentRequirementStatus[]
  permissions       StudentPermission[]
  dailyStatuses     StudentDailyStatus[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model StudentPermission {
  id          String   @id @default(cuid())
  studentId    String
  kind        String   @default("PERMISO_GENERAL")
  reason      String
  notes       String?
  startsAt    DateTime
  endsAt      DateTime
  status      String   @default("PROGRAMADO")
  grantedById String?
  closedById  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  grantedBy   User?    @relation("PermissionGrantedBy", fields: [grantedById], references: [id], onDelete: SetNull)
  closedBy    User?    @relation("PermissionClosedBy", fields: [closedById], references: [id], onDelete: SetNull)

  @@index([studentId, startsAt, endsAt])
  @@index([status])
}

model StudentDailyStatus {
  id           String   @id @default(cuid())
  studentId     String
  date         DateTime
  status       String   @default("AUSENTE")
  notes        String?
  recordedById String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  recordedBy   User?    @relation("DailyStatusRecordedBy", fields: [recordedById], references: [id], onDelete: SetNull)

  @@unique([studentId, date])
  @@index([date, status])
}

model IntakeGroup {
  id         String                   @id @default(cuid())
  schoolCycle String
  semesterLevel Int                   @default(1)
  label      String
  advisorName String?
  shift      String                   @default("MATUTINO")
  capacity   Int                      @default(40)
  isActive   Boolean                  @default(true)
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt
  assignments StudentGroupAssignment[]

  @@unique([schoolCycle, semesterLevel, label, shift])
}

model StudentGroupAssignment {
  id             String                 @id @default(cuid())
  studentId      String                 @unique
  groupId        String
  status         String                 @default("ASIGNADO")
  assignedAt     DateTime               @default(now())
  confirmedAt    DateTime?
  assignedById   String?
  updatedById    String?
  reason         String?
  student        Student                @relation(fields: [studentId], references: [id], onDelete: Cascade)
  group          IntakeGroup            @relation(fields: [groupId], references: [id], onDelete: Restrict)
  assignedBy     User?                  @relation("GroupAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)
  updatedBy      User?                  @relation("GroupUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  auditLogs      GroupAssignmentAudit[]
}

model GroupAssignmentAudit {
  id              String                 @id @default(cuid())
  assignmentId    String
  studentId       String
  beforeGroupId   String?
  beforeGroupLabel String?
  afterGroupId    String?
  afterGroupLabel String?
  actorId         String?
  actorRole       String
  reason          String
  createdAt       DateTime               @default(now())
  assignment      StudentGroupAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student         Student                @relation(fields: [studentId], references: [id], onDelete: Cascade)
  actor           User?                  @relation("GroupAuditActor", fields: [actorId], references: [id], onDelete: SetNull)
}

model StudentAcademicMovement {
  id                      String   @id @default(cuid())
  studentId               String
  movementType            String
  reasonCode              String
  reasonLabel             String
  notes                   String?
  previousSemesterLevel   Int?
  nextSemesterLevel       Int?
  previousGroupId         String?
  previousGroupLabel      String?
  nextGroupId             String?
  nextGroupLabel          String?
  previousEnrollmentStatus String?
  nextEnrollmentStatus    String?
  effectiveDate           DateTime?
  actorId                 String?
  actorRole               String
  createdAt               DateTime @default(now())
  student                 Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  actor                   User?    @relation("AcademicMovementActor", fields: [actorId], references: [id], onDelete: SetNull)
}

model AdmissionPayment {
  id         String   @id @default(cuid())
  folio      String   @unique
  curp       String
  fullName   String
  insurancePaid Boolean @default(false)
  paidAt     DateTime @default(now())
  status     String   @default("PAGADO_PENDIENTE_CAPTURA")
  student    Student?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([curp])
}

model SequenceCounter {
  id        String   @id @default(cuid())
  scope     String   @unique
  lastValue Int      @default(0)
  updatedAt DateTime @updatedAt
}

model EnrollmentRequirement {
  id                String   @id @default(cuid())
  code              String   @unique
  label             String
  requiredOriginals Int      @default(0)
  requiredCopies    Int      @default(0)
  sortOrder         Int      @default(0)
  isActive          Boolean  @default(true)
  statuses          StudentRequirementStatus[]
}

model StudentRequirementStatus {
  id                   String                @id @default(cuid())
  studentId            String
  requirementId        String
  isDelivered          Boolean               @default(false)
  missingJustification String?
  deadlineAt           DateTime?
  notes                String?
  reviewedAt           DateTime?
  reviewedBy           String?
  student              Student               @relation(fields: [studentId], references: [id], onDelete: Cascade)
  requirement          EnrollmentRequirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  @@unique([studentId, requirementId])
}

model PreRegistration {
  id                   String                 @id @default(cuid())
  folio                String                 @unique
  status               String                 @default("PRE_REGISTRO_ENVIADO")
  firstName            String
  paternalLastName     String
  maternalLastName     String
  curp                 String
  birthDate            DateTime?
  sex                  String?
  phone                String?
  studentPhoneSecondary String?
  email                String?
  motherTongue         String?
  addressLine          String
  neighborhood         String?
  locality             String?
  municipality         String?
  state                String?
  postalCode           String?
  previousSchool       String?
  secondaryAverage     Decimal?
  examRoom             String?
  schoolCycle          String
  guardianFullName     String
  guardianRelationship String?
  guardianPhone        String
  guardianPhoneSecondary String?
  guardianEmail        String?
  voucherGeneratedAt   DateTime?
  submittedAt          DateTime?
  reviewedAt           DateTime?
  reviewedBy           String?
  observationNotes     String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  audits               PreRegistrationAudit[]
  student              Student?

  @@unique([curp, schoolCycle])
}

model PreRegistrationAudit {
  id                String          @id @default(cuid())
  preRegistrationId String
  action            String
  actorRole         String
  actorName         String?
  detail            String?
  createdAt         DateTime        @default(now())
  preRegistration   PreRegistration @relation(fields: [preRegistrationId], references: [id], onDelete: Cascade)
}

model Guardian {
  id            String  @id @default(cuid())
  studentId     String  @unique
  fullName      String
  relationship  String?
  phone         String
  secondaryPhone String?
  email         String?
  credentialRef String?
  student       Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model ChargeConcept {
  id          String          @id @default(cuid())
  code        String          @unique
  groupCode   String?
  name        String
  description String?
  isActive    Boolean         @default(true)
  isSuggested Boolean         @default(false)
  excludeFromRoc Boolean      @default(false)
  isLifeInsurance Boolean     @default(false)
  tariffs     ChargeTariff[]
  receiptRows RocReceiptLine[]
  paymentRows CashPaymentLine[]
}

model ChargeTariff {
  id          String        @id @default(cuid())
  conceptId   String
  amount      Decimal
  periodLabel String
  startsAt    DateTime?
  endsAt      DateTime?
  isActive    Boolean       @default(true)
  concept     ChargeConcept @relation(fields: [conceptId], references: [id], onDelete: Restrict)
}

model RocTemplate {
  id          String   @id @default(cuid())
  name        String
  filePath    String
  version     String
  isActive    Boolean  @default(true)
  uploadedAt  DateTime @default(now())
  uploadedBy  String?
}

model RocReceipt {
  id                String           @id @default(cuid())
  rocNumber         String           @unique
  studentId         String
  status            String           @default("EMITIDO")
  amountInWords     String?
  totalAmount       Decimal          @default(0)
  notes             String?
  issuedAt          DateTime         @default(now())
  createdById       String
  templateVersion   String?
  student           Student          @relation(fields: [studentId], references: [id], onDelete: Restrict)
  createdBy         User             @relation("ReceiptCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  lines             RocReceiptLine[]
}

model RocReceiptLine {
  id         String        @id @default(cuid())
  receiptId  String
  conceptId  String
  quantity   Int           @default(1)
  unitAmount Decimal
  total      Decimal
  receipt    RocReceipt    @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  concept    ChargeConcept @relation(fields: [conceptId], references: [id], onDelete: Restrict)
}

model CashPayment {
  id             String            @id @default(cuid())
  studentId      String
  createdById    String
  status         String            @default("PENDIENTE_ROC")
  notes          String?
  batchGeneratedAt DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  student        Student           @relation(fields: [studentId], references: [id], onDelete: Restrict)
  createdBy      User              @relation("CashPaymentCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  lines          CashPaymentLine[]

  @@index([studentId, status])
}

model CashPaymentLine {
  id         String        @id @default(cuid())
  paymentId  String
  conceptId  String
  quantity   Int           @default(1)
  unitAmount Decimal
  total      Decimal
  payment    CashPayment   @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  concept    ChargeConcept @relation(fields: [conceptId], references: [id], onDelete: Restrict)
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  userId      String?
  entityType String
  entityId   String
  action     String
  beforeJson String?
  afterJson  String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}
