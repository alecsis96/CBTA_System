## Cliente desktop compartido (Windows y Mac)
## Este archivo se usa para que ambas apps hablen con el mismo backend en nube.
## Si desplegas en Render, cambia la URL por tu servicio .onrender.com

DATABASE_URL="file:./dev.db"

VITE_HYBRID_API_URL="https://tu-backend-hibrido.example.com"
VITE_HYBRID_API_KEY="cambia-esta-clave-larga"

## Sync offline fallback
VITE_SYNC_API_URL="https://tu-backend-hibrido.example.com/api/sync/op"
VITE_SYNC_API_KEY="cambia-esta-clave-larga"
