# Us? la conexi?n directa para prisma db push / migraciones
BACKEND_DIRECT_URL="postgresql://postgres:[tu-password]@db.[tu-ref].supabase.co:5432/postgres"

SYNC_SERVER_PORT="8787"
SYNC_SERVER_HOST="0.0.0.0"
SYNC_API_KEY="cambia-esta-clave-larga"
SYNC_CORS_ORIGINS="*"

# Cliente desktop (renderer)
VITE_HYBRID_API_URL="https://tu-backend.example.com"
VITE_HYBRID_API_KEY="cambia-esta-clave-larga"

# Sync offline fallback (pueden reutilizar la misma URL/API key)
VITE_SYNC_API_URL="https://tu-backend.example.com/api/sync/op"
VITE_SYNC_API_KEY="cambia-esta-clave-larga"

